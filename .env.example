# Smart Attendance System — Environment Variables
# Copy this file to .env and fill in your values

# Flask secret key (auto-generated if not set)
SECRET_KEY=

# SMTP Email Configuration (for OTP password recovery)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_EMAIL=smartattendance16@gmail.com
SMTP_PASSWORD=your_app_password_here

# Database URL (PostgreSQL — leave empty for local SQLite)
# DATABASE_URL=postgresql://user:pass@host:5432/dbname
